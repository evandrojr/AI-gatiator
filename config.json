      "api_keys": [
        "${GOOGLE_KEY_1}",
        "${GOOGLE_KEY_2}",
        "${GOOGLE_KEY_3}"
      ],
      "default_model": "gemini-2.0-flash",
      "models": [
        "gemini-2.0-flash",
        "gemini-2.5-flash-preview-04-17",
        "gemini-1.5-flash"
      ],
      "headers": {}
