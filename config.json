        "${OPENROUTER_KEY_2}",
        "${OPENROUTER_KEY_3}",
        "${OPENROUTER_KEY_4}",
        "${OPENROUTER_KEY_5}",
        "${OPENROUTER_KEY_6}",
        "${OPENROUTER_KEY_7}"
      ],
      "default_model": "inclusionai/ling-2.6-flash:free",
